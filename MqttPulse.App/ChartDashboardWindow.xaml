<Window x:Class="MqttPulse.App.ChartDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:MqttPulse.App.Controls"
        Title="mqttBoys Charts"
        Icon="Assets/mqttBoys.ico"
        Width="1000"
        Height="700"
        MinWidth="760"
        MinHeight="480"
        Background="#EEF3F2"
        FontFamily="Segoe UI"
        FontSize="13"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    <Window.Resources>
        <SolidColorBrush x:Key="InkBrush" Color="#14201E" />
        <SolidColorBrush x:Key="MutedBrush" Color="#536763" />
        <SolidColorBrush x:Key="AccentBrush" Color="#176E63" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#105B52" />
        <SolidColorBrush x:Key="BorderBrush" Color="#C7D3D1" />
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="#F5F8F7" />

        <Style x:Key="ChartButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonSurface"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background" Value="#E3F0ED" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background" Value="#D4E7E3" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonSurface" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button"
               BasedOn="{StaticResource ChartButtonStyle}" />

        <Style x:Key="HeaderButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource ChartButtonStyle}">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#234B47" />
            <Setter Property="BorderBrush" Value="#3A625E" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#183B38"
                Padding="14,7">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal">
                    <Button Content="Pause all"
                            Command="{Binding PauseAllCommand}"
                            Style="{StaticResource HeaderButtonStyle}"
                            Margin="0,0,6,0" />
                    <Button Content="Resume all"
                            Command="{Binding ResumeAllCommand}"
                            Style="{StaticResource HeaderButtonStyle}"
                            Margin="0,0,6,0" />
                    <Button Content="Clear all"
                            Command="{Binding ClearAllCommand}"
                            Style="{StaticResource HeaderButtonStyle}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="Charts"
                               Foreground="White"
                               FontSize="16"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding ChartCountText}"
                               Foreground="#B7CBC7"
                               Margin="12,1,0,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <ScrollViewer x:Name="ChartScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="8">
                <ItemsControl x:Name="ChartItems"
                              ItemsSource="{Binding Charts}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel IsItemsHost="True" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="430"
                                    Height="282"
                                    Margin="6"
                                    Padding="10"
                                    Background="White"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="26" />
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0" Margin="0,0,0,7">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding MetricTitle}"
                                                       FontWeight="SemiBold"
                                                       FontSize="14"
                                                       Foreground="{StaticResource InkBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Topic}"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       FontSize="11.5"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Content="{Binding PauseButtonText}"
                                                Command="{Binding TogglePauseCommand}"
                                                MinWidth="68"
                                                Margin="8,0,6,0"
                                                ToolTip="Pause or resume this chart" />
                                        <Button Grid.Column="2"
                                                Content="Close"
                                                Command="{Binding RemoveCommand}"
                                                ToolTip="Remove this chart" />
                                    </Grid>

                                    <controls:LiveScalarChart Grid.Row="1"
                                                              Points="{Binding DisplayPoints}"
                                                              IsBoolean="{Binding IsBoolean}"
                                                              SeriesBrush="{Binding SeriesBrush}" />

                                    <Grid Grid.Row="2" Margin="2,4,2,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding StatusText}"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding LatestValueText}"
                                                   Foreground="{StaticResource InkBrush}"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <TextBlock Text="No charts"
                       Visibility="{Binding EmptyVisibility}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource MutedBrush}"
                       FontSize="15" />
        </Grid>
    </Grid>
</Window>
