<Window x:Class="MqttPulse.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:MqttPulse.App.ViewModels"
        xmlns:controls="clr-namespace:MqttPulse.App.Controls"
        mc:Ignorable="d"
        Title="mqttBoys"
        Icon="Assets/mqttBoys.ico"
        Height="900"
        Width="1440"
        MinHeight="720"
        MinWidth="1100"
        Background="#EEF3F2"
        FontFamily="Segoe UI"
        FontSize="13"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextHintingMode="Fixed">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="CanvasBrush" Color="#EEF3F2" />
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="#F5F8F7" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#C7D3D1" />
        <SolidColorBrush x:Key="BorderBrushStrong" Color="#91A8A4" />
        <SolidColorBrush x:Key="InputBorderBrush" Color="#AABCB8" />
        <SolidColorBrush x:Key="InkBrush" Color="#14201E" />
        <SolidColorBrush x:Key="MutedBrush" Color="#3F5652" />
        <SolidColorBrush x:Key="AccentBrush" Color="#176E63" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#105B52" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#E3F0ED" />
        <SolidColorBrush x:Key="ChromeBrush" Color="#183B38" />
        <SolidColorBrush x:Key="DangerBrush" Color="#B13B3B" />
        <SolidColorBrush x:Key="CodeBackgroundBrush" Color="#FBFCFC" />
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#D8EBE7" />
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#14201E" />
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#E7F1EF" />
        <DropShadowEffect x:Key="ModalShadow"
                          BlurRadius="16"
                          ShadowDepth="6"
                          Opacity="0.18"
                          Color="#14201E" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#173B37" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="ModalTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>

        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="9,5" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#F1F4F3" />
                    <Setter Property="Foreground" Value="#83918E" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}" />
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.55" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#D4E7E3" />
                </Trigger>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.46" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentHoverBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#0B4C45" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#234B47" />
            <Setter Property="BorderBrush" Value="#3A625E" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2D5A55" />
                    <Setter Property="BorderBrush" Value="#5B7C78" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="QuietButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="9,4" />
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
            <Setter Property="Background" Value="#FFF8F8" />
            <Setter Property="BorderBrush" Value="#E6CACA" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FCEDED" />
                    <Setter Property="BorderBrush" Value="#D8AFAF" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TreeView">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="2" />
        </Style>

        <Style TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
        </Style>

        <Style x:Key="ProfileTreeItemStyle"
               TargetType="TreeViewItem"
               BasedOn="{StaticResource {x:Type TreeViewItem}}">
            <Setter Property="AutomationProperties.Name" Value="{Binding Name}" />
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#E5ECEA" />
            <Setter Property="RowBackground" Value="White" />
            <Setter Property="AlternatingRowBackground" Value="#F8FAFA" />
            <Setter Property="RowHeight" Value="32" />
            <Setter Property="ColumnHeaderHeight" Value="34" />
            <Setter Property="CanUserResizeRows" Value="False" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="BorderThickness" Value="0" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EEF6F4" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#D8EBE7" />
                    <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <HierarchicalDataTemplate DataType="{x:Type vm:TopicViewModel}"
                                  ItemsSource="{Binding Children}">
            <Grid MinHeight="23" ClipToBounds="True">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding DisplayName}"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="1"
                           Text="{Binding DetailText}"
                           Margin="7,0,0,0"
                           Foreground="{StaticResource MutedBrush}"
                           TextTrimming="CharacterEllipsis" />
            </Grid>
        </HierarchicalDataTemplate>

        <HierarchicalDataTemplate DataType="{x:Type vm:ProfileTreeNodeViewModel}"
                                  ItemsSource="{Binding Children}">
            <Grid Margin="1,3" MinHeight="30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Text="{Binding Name}"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Row="1"
                           Text="{Binding DetailText}"
                           Foreground="{StaticResource MutedBrush}"
                           FontSize="12"
                           TextTrimming="CharacterEllipsis" />
            </Grid>
        </HierarchicalDataTemplate>
    </Window.Resources>

    <Grid>
        <DockPanel LastChildFill="True">
            <Border DockPanel.Dock="Top"
                    Height="58"
                    Background="{StaticResource ChromeBrush}"
                    Padding="14,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" MinWidth="160" />
                        <ColumnDefinition Width="260" />
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Image Source="Assets/mqttBoys.ico"
                               Width="28"
                               Height="28"
                               Margin="0,0,9,0" />
                        <TextBlock Text="mqttBoys"
                                   Foreground="White"
                                   FontSize="19"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <Button Grid.Column="1"
                             Content="Connections"
                             Command="{Binding OpenConnectionManagerCommand}"
                             Style="{StaticResource ToolbarButtonStyle}"
                             Margin="0,0,8,0" />

                    <Button Grid.Column="2"
                             Content="주기 체크"
                             Command="{Binding OpenPeriodCheckCommand}"
                             Style="{StaticResource ToolbarButtonStyle}"
                             Margin="0,0,12,0" />

                    <TextBlock Grid.Column="3"
                               Text="{Binding SelectedProfileCaption}"
                               Foreground="#D9E8E5"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />

                    <TextBox Grid.Column="4"
                              Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                              ToolTip="Topic search"
                              MinWidth="220"
                              Margin="14,0,0,0" />

                    <TextBlock Grid.Column="5"
                               Text="{Binding StatusMessage}"
                               Foreground="#D9E8E5"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Margin="18,0" />

                    <StackPanel Grid.Column="6"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="{Binding TopicCount, StringFormat=Topics {0:N0}}"
                                   Foreground="#EDF5F3"
                                   Margin="0,0,12,0" />
                        <TextBlock Text="{Binding ReceivedMessages, StringFormat=Messages {0:N0}}"
                                   Foreground="#EDF5F3"
                                   Margin="0,0,12,0" />
                        <TextBlock Text="{Binding PendingCount, StringFormat=Queue {0:N0}}"
                                   Foreground="#BFD7D2" />
                    </StackPanel>

                    <StackPanel Grid.Column="8"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="16,0,0,0">
                        <Button Content="Connect"
                                 Command="{Binding ConnectCommand}"
                                 Style="{StaticResource PrimaryButtonStyle}"
                                 Margin="0,0,8,0" />
                        <Button Content="Disconnect"
                                Command="{Binding DisconnectCommand}"
                                Style="{StaticResource ToolbarButtonStyle}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Margin="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="4*" MinWidth="410" />
                    <ColumnDefinition Width="6" />
                    <ColumnDefinition Width="5*" MinWidth="560" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource PanelBorderStyle}"
                        Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,10">
                            <Button DockPanel.Dock="Right"
                                    Content="Clear"
                                    Command="{Binding ClearTopicsCommand}"
                                    Style="{StaticResource QuietButtonStyle}" />
                            <TextBlock Text="Topics"
                                       Style="{StaticResource SectionTitleStyle}" />
                        </DockPanel>

                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding SearchResults}"
                                 SelectedItem="{Binding SelectedTopic, Mode=TwoWay}"
                                 Visibility="{Binding SearchResultsVisibility}"
                                 MaxHeight="160"
                                 Margin="0,0,0,6"
                                 BorderBrush="{StaticResource BorderBrushSoft}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:TopicViewModel}">
                                    <TextBlock Text="{Binding FullTopic}"
                                               TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TreeView x:Name="TopicTree"
                                  Grid.Row="2"
                                  ItemsSource="{Binding RootTopics}"
                                  SelectedItemChanged="TopicTree_SelectedItemChanged"
                                  BorderThickness="0"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  ScrollViewer.CanContentScroll="True"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto" />
                    </Grid>
                </Border>

                <GridSplitter Grid.Column="1"
                              HorizontalAlignment="Stretch"
                              Background="{StaticResource BorderBrushSoft}" />

                <Border Grid.Column="2"
                        Style="{StaticResource PanelBorderStyle}"
                        Padding="12">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="0,0,16,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="340" MinHeight="280" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="300" MinHeight="240" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="300" MinHeight="250" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="220" MinHeight="200" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <DockPanel Margin="0,0,0,9">
                                <Button DockPanel.Dock="Right"
                                        Content="Copy"
                                        Command="{Binding CopyValueCommand}"
                                        Style="{StaticResource QuietButtonStyle}" />
                                <TextBlock Text="Value"
                                           Style="{StaticResource SectionTitleStyle}" />
                            </DockPanel>
                            <controls:JsonPayloadViewer Grid.Row="1"
                                                        Text="{Binding ValuePayloadText, Mode=OneWay}"
                                                        FontFamily="Consolas"
                                                        FontSize="12"
                                                        VerticalScrollBarVisibility="Auto"
                                                        HorizontalScrollBarVisibility="Auto"
                                                        BorderBrush="{StaticResource BorderBrushSoft}"
                                                        Background="{StaticResource CodeBackgroundBrush}" />
                        </Grid>

                        <GridSplitter Grid.Row="1"
                                      HorizontalAlignment="Stretch"
                                      Background="{StaticResource BorderBrushSoft}" />

                        <Grid Grid.Row="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <DockPanel Margin="0,0,0,9">
                                <Button DockPanel.Dock="Right"
                                        Content="Copy"
                                        Command="{Binding CopySelectedCommand}"
                                        Style="{StaticResource QuietButtonStyle}" />
                                <TextBlock Text="Selected"
                                           Style="{StaticResource SectionTitleStyle}" />
                            </DockPanel>
                            <controls:JsonPayloadViewer Grid.Row="1"
                                                        Text="{Binding SelectedPayloadText, Mode=OneWay}"
                                                        FontFamily="Consolas"
                                                        FontSize="12"
                                                        VerticalScrollBarVisibility="Auto"
                                                        HorizontalScrollBarVisibility="Auto"
                                                        BorderBrush="{StaticResource BorderBrushSoft}"
                                                        Background="{StaticResource CodeBackgroundBrush}" />
                        </Grid>

                        <GridSplitter Grid.Row="3"
                                      HorizontalAlignment="Stretch"
                                      Background="{StaticResource BorderBrushSoft}" />

                        <Grid Grid.Row="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <DockPanel Margin="0,0,0,9">
                                <Button DockPanel.Dock="Right"
                                        Content="{Binding HistoryPauseButtonText}"
                                        Command="{Binding ToggleHistoryPauseCommand}"
                                        Style="{StaticResource QuietButtonStyle}" />
                                <TextBlock Text="History"
                                           Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="{Binding SelectedTopicAveragePeriodText}"
                                           Foreground="{StaticResource MutedBrush}"
                                           VerticalAlignment="Center"
                                           Margin="12,0,0,0" />
                            </DockPanel>
                            <DataGrid Grid.Row="1"
                                      ItemsSource="{Binding SelectedTopicHistory}"
                                      SelectedItem="{Binding SelectedHistoryItem, Mode=TwoWay}"
                                      AutoGenerateColumns="False"
                                      HeadersVisibility="Column"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      EnableRowVirtualization="True"
                                      EnableColumnVirtualization="True"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling"
                                      BorderBrush="{StaticResource BorderBrushSoft}"
                                      RowHeight="28">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Time" Binding="{Binding ReceivedAtWithDeltaText}" Width="290" />
                                    <DataGridTextColumn Header="Payload" Binding="{Binding PayloadPreview}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>

                        <GridSplitter Grid.Row="5"
                                      HorizontalAlignment="Stretch"
                                      Background="{StaticResource BorderBrushSoft}" />

                        <Grid Grid.Row="6">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Publish"
                                       Style="{StaticResource SectionTitleStyle}"
                                       Margin="0,0,0,9" />
                            <TextBox Grid.Row="1"
                                     Text="{Binding PublishTopic, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,8" />
                            <TextBox Grid.Row="2"
                                     Text="{Binding PublishPayload, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     AcceptsTab="True"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     VerticalContentAlignment="Top"
                                     Background="{StaticResource CodeBackgroundBrush}" />
                            <Grid Grid.Row="3" Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="QoS" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding QosOptions}"
                                          SelectedItem="{Binding PublishQos}" />
                                <CheckBox Grid.Column="2"
                                          Content="retain"
                                          IsChecked="{Binding PublishRetain}"
                                          VerticalAlignment="Center"
                                          Margin="14,0" />
                                <Button Grid.Column="4"
                                        Content="Format JSON"
                                        Command="{Binding FormatPublishJsonCommand}"
                                        Margin="0,0,8,0" />
                                <Button Grid.Column="5"
                                        Content="Publish"
                                        Command="{Binding PublishCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        MinWidth="100" />
                            </Grid>
                        </Grid>
                    </Grid>
                    </ScrollViewer>
                </Border>
            </Grid>
        </DockPanel>

        <Grid Visibility="{Binding ConnectionManagerVisibility}"
              Background="#B3182422">
            <Grid Width="1040"
                  Height="680"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  UseLayoutRounding="True"
                  SnapsToDevicePixels="True">
                <Border Background="White"
                        CornerRadius="8"
                        Effect="{StaticResource ModalShadow}"
                        IsHitTestVisible="False" />
                <Border Background="White"
                        BorderBrush="{StaticResource BorderBrushStrong}"
                        BorderThickness="1"
                        CornerRadius="8"
                        SnapsToDevicePixels="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="58" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="64" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300" />
                        <ColumnDefinition Width="1" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Row="0"
                            Grid.ColumnSpan="3"
                            Background="#FBFCFC"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="0,0,0,1"
                            Padding="20,0">
                        <DockPanel>
                            <Button DockPanel.Dock="Right"
                                    Content="Close"
                                    Command="{Binding CloseConnectionManagerCommand}"
                                    Style="{StaticResource QuietButtonStyle}"
                                    VerticalAlignment="Center" />
                            <TextBlock Text="Connections"
                                       Style="{StaticResource ModalTitleStyle}" />
                        </DockPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Grid.Column="0"
                            Background="#F0F5F4"
                            Padding="16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Saved connections"
                                       Style="{StaticResource SectionTitleStyle}"
                                       Margin="2,0,0,12" />

                            <TreeView x:Name="ProfileTree"
                                      Grid.Row="1"
                                      ItemsSource="{Binding ProfileTree}"
                                      ItemContainerStyle="{StaticResource ProfileTreeItemStyle}"
                                      SelectedItemChanged="ProfileTree_SelectedItemChanged"
                                      PreviewMouseLeftButtonDown="ProfileTree_PreviewMouseLeftButtonDown"
                                      MouseMove="ProfileTree_MouseMove"
                                      DragOver="ProfileTree_DragOver"
                                      Drop="ProfileTree_Drop"
                                      AllowDrop="True"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto" />

                            <Grid Grid.Row="2" Margin="0,14,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <UniformGrid Columns="2">
                                    <Button Content="Add broker"
                                            Command="{Binding AddProfileCommand}"
                                            Margin="0,0,4,4" />
                                    <Button Content="Add folder"
                                            Command="{Binding AddFolderCommand}"
                                            Margin="4,0,0,4" />
                                </UniformGrid>
                                <UniformGrid Grid.Row="1" Columns="2">
                                    <Button Content="Delete broker"
                                            Command="{Binding DeleteProfileCommand}"
                                            Style="{StaticResource DangerButtonStyle}"
                                            Margin="0,4,4,0" />
                                    <Button Content="Delete folder"
                                            Command="{Binding DeleteFolderCommand}"
                                            Style="{StaticResource DangerButtonStyle}"
                                            Margin="4,4,0,0" />
                                </UniformGrid>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Grid.Column="1"
                            Background="{StaticResource BorderBrushSoft}" />

                    <ScrollViewer Grid.Row="1"
                                  Grid.Column="2"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="24,18,20,18">
                        <Grid>
                            <StackPanel Visibility="{Binding BrokerEditorVisibility}">
                                <TextBlock Text="Broker"
                                           Style="{StaticResource SectionTitleStyle}"
                                           Margin="0,0,0,10" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="2*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Folder" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBox Grid.Row="1" Grid.Column="0" Text="{Binding SelectedProfile.Name, UpdateSourceTrigger=PropertyChanged}" />
                                    <ComboBox x:Name="FolderCombo"
                                              Grid.Row="1"
                                              Grid.Column="2"
                                              ItemsSource="{Binding FolderOptions}"
                                              SelectedItem="{Binding SelectedProfileFolderPath, Mode=OneWay}"
                                              SelectionChanged="FolderCombo_SelectionChanged"
                                              IsEditable="False" />
                                </Grid>

                                <Border Height="1"
                                        Background="{StaticResource BorderBrushSoft}"
                                        Margin="0,18" />

                                <TextBlock Text="Connection"
                                           Style="{StaticResource SectionTitleStyle}"
                                           Margin="0,0,0,10" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="160" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Protocol" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Host" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBlock Grid.Row="0" Grid.Column="4" Text="Port" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBlock Grid.Row="0" Grid.Column="6" Text="WS path" Style="{StaticResource FieldLabelStyle}" />
                                    <ComboBox Grid.Row="1" Grid.Column="0" ItemsSource="{Binding TransportOptions}" SelectedItem="{Binding SelectedProfile.Transport, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding SelectedProfile.Host, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Grid.Row="1" Grid.Column="4" Text="{Binding SelectedProfile.Port, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Grid.Row="1" Grid.Column="6" Text="{Binding SelectedProfile.WebSocketPath, UpdateSourceTrigger=PropertyChanged}" />
                                    <StackPanel Grid.Row="2"
                                                Grid.Column="0"
                                                Grid.ColumnSpan="7"
                                                Orientation="Horizontal"
                                                Margin="0,12,0,0">
                                        <CheckBox Content="Encryption (TLS)"
                                                  IsChecked="{Binding SelectedProfile.UseTls}"
                                                  Margin="0,0,24,0" />
                                        <CheckBox Content="Validate certificate"
                                                  IsChecked="{Binding SelectedProfile.ValidateCertificate}" />
                                    </StackPanel>
                                </Grid>

                                <Border Height="1"
                                        Background="{StaticResource BorderBrushSoft}"
                                        Margin="0,18" />

                                <TextBlock Text="Session"
                                           Style="{StaticResource SectionTitleStyle}"
                                           Margin="0,0,0,10" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="110" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Client ID" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Subscribe" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBlock Grid.Row="0" Grid.Column="4" Text="History" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBox Grid.Row="1" Grid.Column="0" Text="{Binding SelectedProfile.ClientId, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding SelectedProfile.SubscribeTopic, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Grid.Row="1" Grid.Column="4" Text="{Binding SelectedProfile.MaxHistoryPerTopic, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>

                                <Border Height="1"
                                        Background="{StaticResource BorderBrushSoft}"
                                        Margin="0,18" />

                                <TextBlock Text="Credentials"
                                           Style="{StaticResource SectionTitleStyle}"
                                           Margin="0,0,0,10" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Username" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Password" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBox Grid.Row="1" Grid.Column="0" Text="{Binding SelectedProfile.Username, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding SelectedProfile.Password, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>

                                <Expander IsExpanded="{Binding SelectedProfile.EnableSshTunnel, Mode=TwoWay}"
                                          Margin="0,18,0,0">
                                    <Expander.Header>
                                        <CheckBox Content="Use SSH tunnel"
                                                  IsChecked="{Binding SelectedProfile.EnableSshTunnel, Mode=TwoWay}"
                                                  FontWeight="SemiBold" />
                                    </Expander.Header>
                                    <Border Background="{StaticResource SurfaceAltBrush}"
                                            BorderBrush="{StaticResource BorderBrushSoft}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="14"
                                            Margin="0,10,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="16" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="100" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="12" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="12" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="SSH host" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBlock Grid.Row="0" Grid.Column="2" Text="SSH port" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBlock Grid.Row="0" Grid.Column="4" Text="SSH user" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBlock Grid.Row="0" Grid.Column="6" Text="Local port" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBox Grid.Row="1" Grid.Column="0" Text="{Binding SelectedProfile.SshHost, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding SelectedProfile.SshPort, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBox Grid.Row="1" Grid.Column="4" Text="{Binding SelectedProfile.SshUsername, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBox Grid.Row="1" Grid.Column="6" Text="{Binding SelectedProfile.SshLocalPort, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="7" Text="Private key" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBox Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="7" Text="{Binding SelectedProfile.SshPrivateKeyPath, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Grid.Row="6"
                                                       Grid.Column="0"
                                                       Grid.ColumnSpan="7"
                                                       Text="Uses OpenSSH config, a private key, or ssh-agent. Broker Host and Port remain the target visible from the SSH host."
                                                       Foreground="{StaticResource MutedBrush}"
                                                       FontSize="12"
                                                       TextWrapping="Wrap" />
                                        </Grid>
                                    </Border>
                                </Expander>
                            </StackPanel>

                            <StackPanel Visibility="{Binding FolderEditorVisibility}">
                                <TextBlock Text="Folder"
                                           Style="{StaticResource SectionTitleStyle}"
                                           Margin="0,0,0,14" />
                                <TextBlock Text="Name" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Text="{Binding SelectedFolderName, UpdateSourceTrigger=PropertyChanged}" />

                                <Grid Margin="0,18,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Path" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedFolderFullPath}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Parent" Style="{StaticResource FieldLabelStyle}" Margin="0,12,0,5" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedFolderParentPath}" TextTrimming="CharacterEllipsis" Margin="0,12,0,5" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedFolderSummaryText}" Foreground="{StaticResource MutedBrush}" Margin="0,12,0,0" />
                                </Grid>

                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            Margin="0,20,0,0">
                                    <Button Content="Rename folder"
                                            Command="{Binding RenameFolderCommand}"
                                            Margin="0,0,8,0" />
                                    <Button Content="Delete folder"
                                            Command="{Binding DeleteFolderCommand}"
                                            Style="{StaticResource DangerButtonStyle}" />
                                </StackPanel>
                            </StackPanel>

                            <Grid Visibility="{Binding EmptyConnectionEditorVisibility}">
                                <TextBlock Text="Select a broker or folder"
                                           Style="{StaticResource SectionTitleStyle}"
                                           Foreground="{StaticResource MutedBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Grid>
                    </ScrollViewer>

                    <Border Grid.Row="2"
                            Grid.ColumnSpan="3"
                            Background="{StaticResource SurfaceAltBrush}"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="0,1,0,0"
                            Padding="18,0">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <Button Content="Save changes"
                                    Command="{Binding SaveProfilesCommand}"
                                    Margin="0,0,10,0" />
                            <Button Content="Connect"
                                    Command="{Binding ConnectCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    MinWidth="116" />
                        </StackPanel>
                    </Border>
                </Grid>
                </Border>
            </Grid>
        </Grid>
        <Grid x:Name="PeriodCheckPanel"
              Visibility="{Binding PeriodCheckVisibility}"
              IsVisibleChanged="PeriodCheckPanel_IsVisibleChanged"
              Background="#B3182422">
            <Grid Width="920"
                  Height="650"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  UseLayoutRounding="True"
                  SnapsToDevicePixels="True">
                <Border Background="White"
                        CornerRadius="8"
                        Effect="{StaticResource ModalShadow}"
                        IsHitTestVisible="False" />
                <Border Background="White"
                        BorderBrush="{StaticResource BorderBrushStrong}"
                        BorderThickness="1"
                        CornerRadius="8"
                        SnapsToDevicePixels="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="58" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#FBFCFC"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="0,0,0,1"
                            Padding="20,0">
                        <DockPanel>
                            <Button DockPanel.Dock="Right"
                                    Content="닫기"
                                    Command="{Binding ClosePeriodCheckCommand}"
                                    Style="{StaticResource QuietButtonStyle}"
                                    VerticalAlignment="Center" />
                            <TextBlock Text="주기 체크"
                                       Style="{StaticResource ModalTitleStyle}" />
                            <Border Background="{StaticResource AccentSoftBrush}"
                                    CornerRadius="5"
                                    Padding="9,4"
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding PeriodCheckRunningText}"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontWeight="SemiBold" />
                            </Border>
                        </DockPanel>
                    </Border>

                    <Grid Grid.Row="1" Margin="22,18,22,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="180" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Text="토픽"
                                       Style="{StaticResource FieldLabelStyle}" />
                            <Grid x:Name="PeriodTopicInputHost"
                                  Grid.Row="1"
                                  Grid.Column="0">
                                <TextBox x:Name="PeriodTopicInput"
                                         Text="{Binding PeriodCheckTopicText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="9,5,36,5"
                                         IsEnabled="{Binding IsPeriodCheckIdle}"
                                         TextChanged="PeriodTopicInput_TextChanged"
                                         GotKeyboardFocus="PeriodTopicInput_GotKeyboardFocus"
                                         PreviewKeyDown="PeriodTopicInput_PreviewKeyDown" />
                                <Button HorizontalAlignment="Right"
                                        VerticalAlignment="Stretch"
                                        Width="34"
                                        MinHeight="0"
                                        Padding="0"
                                        Content="▼"
                                        FontSize="9"
                                        Foreground="{StaticResource MutedBrush}"
                                        Style="{StaticResource QuietButtonStyle}"
                                        ToolTip="토픽 목록 열기"
                                        Click="PeriodTopicDropButton_Click" />
                                <Popup x:Name="PeriodTopicPopup"
                                       PlacementTarget="{Binding ElementName=PeriodTopicInputHost}"
                                       DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                       Placement="Bottom"
                                       VerticalOffset="2"
                                       AllowsTransparency="True"
                                       StaysOpen="False"
                                       Focusable="False">
                                    <Border Width="{Binding ActualWidth, ElementName=PeriodTopicInputHost}"
                                            MaxHeight="264"
                                            Background="White"
                                            BorderBrush="{StaticResource BorderBrushStrong}"
                                            BorderThickness="1"
                                            SnapsToDevicePixels="True">
                                        <ListBox x:Name="PeriodTopicSuggestionList"
                                                 ItemsSource="{Binding PeriodCheckTopicSuggestions}"
                                                 Background="White"
                                                 BorderThickness="0"
                                                 Padding="0,3"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                 PreviewMouseLeftButtonUp="PeriodTopicSuggestionList_PreviewMouseLeftButtonUp">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}"
                                                               TextTrimming="CharacterEllipsis" />
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="Padding" Value="9,6" />
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                    <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
                                                    <Setter Property="Background" Value="White" />
                                                    <Setter Property="Cursor" Value="Hand" />
                                                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter Property="Background" Value="#CFE6E1" />
                                                            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                        </ListBox>
                                    </Border>
                                </Popup>
                            </Grid>
                            <Button Grid.Row="1"
                                    Grid.Column="2"
                                    Content="측정 시작"
                                    Command="{Binding StartPeriodCheckCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    MinHeight="36" />
                        </Grid>

                        <Border Grid.Row="1"
                                Background="{StaticResource AccentSoftBrush}"
                                CornerRadius="6"
                                Padding="12,10"
                                Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="상태"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentBrush}"
                                           Margin="0,0,12,0" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding PeriodCheckStatus}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="2"
                                           Text="10초 측정"
                                           Foreground="{StaticResource MutedBrush}"
                                           Margin="16,0,0,0" />
                            </Grid>
                        </Border>

                        <Grid Grid.Row="2" Margin="0,0,0,16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="현재 결과"
                                       Style="{StaticResource SectionTitleStyle}"
                                       Margin="0,0,0,8" />
                            <TextBox Grid.Row="1"
                                     Text="{Binding PeriodCheckResultText, Mode=OneWay}"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     Background="{StaticResource CodeBackgroundBrush}"
                                     BorderBrush="{StaticResource BorderBrushSoft}"
                                     VerticalContentAlignment="Top" />
                        </Grid>

                        <Grid Grid.Row="3">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock DockPanel.Dock="Right"
                                           Text="앱 종료 시 초기화"
                                           Foreground="{StaticResource MutedBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="측정 기록"
                                           Style="{StaticResource SectionTitleStyle}" />
                            </DockPanel>
                            <DataGrid Grid.Row="1"
                                      ItemsSource="{Binding PeriodCheckHistory}"
                                      SelectedItem="{Binding SelectedPeriodCheckHistoryItem, Mode=TwoWay}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      EnableRowVirtualization="True"
                                      EnableColumnVirtualization="True"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="완료 시각" Binding="{Binding CompletedAtText}" Width="165" />
                                    <DataGridTextColumn Header="토픽" Binding="{Binding Topic}" Width="2*" />
                                    <DataGridTextColumn Header="결과" Binding="{Binding Summary}" Width="3*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Grid>
                </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
