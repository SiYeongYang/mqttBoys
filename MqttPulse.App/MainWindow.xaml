<Window x:Class="MqttPulse.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:MqttPulse.App.ViewModels"
        xmlns:controls="clr-namespace:MqttPulse.App.Controls"
        mc:Ignorable="d"
        Title="mqttBoys"
        Icon="Assets/mqttBoys.ico"
        Height="900"
        Width="1440"
        MinHeight="720"
        MinWidth="1100"
        Background="#EEF3F2"
        FontFamily="Segoe UI"
        FontSize="13"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextHintingMode="Fixed">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="CanvasBrush" Color="#EEF3F2" />
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="#F5F8F7" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#C7D3D1" />
        <SolidColorBrush x:Key="BorderBrushStrong" Color="#91A8A4" />
        <SolidColorBrush x:Key="InputBorderBrush" Color="#AABCB8" />
        <SolidColorBrush x:Key="InkBrush" Color="#14201E" />
        <SolidColorBrush x:Key="MutedBrush" Color="#3F5652" />
        <SolidColorBrush x:Key="AccentBrush" Color="#176E63" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#105B52" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#E3F0ED" />
        <SolidColorBrush x:Key="ChromeBrush" Color="#183B38" />
        <SolidColorBrush x:Key="DangerBrush" Color="#B13B3B" />
        <SolidColorBrush x:Key="CodeBackgroundBrush" Color="#FBFCFC" />
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#D8EBE7" />
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#14201E" />
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#E7F1EF" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <DropShadowEffect x:Key="ModalShadow"
                          BlurRadius="16"
                          ShadowDepth="6"
                          Opacity="0.18"
                          Color="#14201E" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#173B37" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="ModalTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>

        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="9,5" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#F1F4F3" />
                    <Setter Property="Foreground" Value="#83918E" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}" />
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.55" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#D4E7E3" />
                </Trigger>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.46" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentHoverBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#0B4C45" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#234B47" />
            <Setter Property="BorderBrush" Value="#3A625E" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2D5A55" />
                    <Setter Property="BorderBrush" Value="#5B7C78" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="QuietButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="9,4" />
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
            <Setter Property="Background" Value="#FFF8F8" />
            <Setter Property="BorderBrush" Value="#E6CACA" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FCEDED" />
                    <Setter Property="BorderBrush" Value="#D8AFAF" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ScrollPageButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollThumbStyle" TargetType="Thumb">
            <Setter Property="MinWidth" Value="4" />
            <Setter Property="MinHeight" Value="4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbSurface"
                                Margin="1"
                                Background="#AABAB7"
                                CornerRadius="3" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbSurface" Property="Background" Value="#718B86" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbSurface" Property="Background" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Focusable" Value="False" />
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="7" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Border Background="{TemplateBinding Background}">
                                    <Track x:Name="PART_Track"
                                           IsDirectionReversed="True"
                                           Orientation="Vertical">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}"
                                                          CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                                          Style="{StaticResource ScrollPageButtonStyle}" />
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource ScrollThumbStyle}" />
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}"
                                                          CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                                          Style="{StaticResource ScrollPageButtonStyle}" />
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="7" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Border Background="{TemplateBinding Background}">
                                    <Track x:Name="PART_Track"
                                           IsDirectionReversed="False"
                                           Orientation="Horizontal">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Command="{x:Static ScrollBar.PageLeftCommand}"
                                                          CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                                          Style="{StaticResource ScrollPageButtonStyle}" />
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource ScrollThumbStyle}" />
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Command="{x:Static ScrollBar.PageRightCommand}"
                                                          CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                                          Style="{StaticResource ScrollPageButtonStyle}" />
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="VerticalSplitterStyle" TargetType="GridSplitter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridSplitter">
                        <Grid Background="Transparent">
                            <Border x:Name="SplitterLine"
                                    Width="1"
                                    HorizontalAlignment="Center"
                                    Background="{StaticResource BorderBrushSoft}" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SplitterLine" Property="Width" Value="2" />
                                <Setter TargetName="SplitterLine" Property="Background" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HorizontalSplitterStyle" TargetType="GridSplitter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridSplitter">
                        <Grid Background="Transparent">
                            <Border x:Name="SplitterLine"
                                    Height="1"
                                    VerticalAlignment="Center"
                                    Background="{StaticResource BorderBrushSoft}" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SplitterLine" Property="Height" Value="2" />
                                <Setter TargetName="SplitterLine" Property="Background" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TreeView">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="2" />
        </Style>

        <Style TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSearchVisible}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ProfileTreeItemStyle"
               TargetType="TreeViewItem"
               BasedOn="{StaticResource {x:Type TreeViewItem}}">
            <Setter Property="AutomationProperties.Name" Value="{Binding Name}" />
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#E5ECEA" />
            <Setter Property="RowBackground" Value="White" />
            <Setter Property="AlternatingRowBackground" Value="#F8FAFA" />
            <Setter Property="RowHeight" Value="32" />
            <Setter Property="ColumnHeaderHeight" Value="34" />
            <Setter Property="CanUserResizeRows" Value="False" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="BorderThickness" Value="0" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EEF6F4" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#D8EBE7" />
                    <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <HierarchicalDataTemplate DataType="{x:Type vm:TopicViewModel}"
                                  ItemsSource="{Binding Children}">
            <Grid MinHeight="23" ClipToBounds="True">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding DisplayName}"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="1"
                           Text="{Binding DetailText}"
                           Margin="7,0,0,0"
                           Foreground="{StaticResource MutedBrush}"
                           TextTrimming="CharacterEllipsis" />
            </Grid>
        </HierarchicalDataTemplate>

        <HierarchicalDataTemplate DataType="{x:Type vm:ProfileTreeNodeViewModel}"
                                  ItemsSource="{Binding Children}">
            <Grid Margin="1,2" MinHeight="28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid x:Name="FolderIcon"
                      Width="15"
                      Height="14"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Top"
                      Margin="0,2,0,0"
                      ToolTip="Folder">
                    <Border Width="7"
                            Height="4"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Background="#D9871F"
                            CornerRadius="1" />
                    <Border Margin="0,3,0,0"
                            Background="#E69A2E"
                            CornerRadius="1" />
                    <Border Margin="1,5,1,2"
                            Background="#F2B24D"
                            CornerRadius="1" />
                </Grid>

                <Grid x:Name="BrokerIcon"
                      Width="14"
                      Height="14"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Top"
                      Margin="0,2,0,0"
                      Visibility="Collapsed"
                      ToolTip="Broker">
                    <Border Height="5"
                            VerticalAlignment="Top"
                            Background="#337FAE"
                            CornerRadius="7,7,2,2" />
                    <Border Margin="0,3,0,2"
                            Background="#4593C1" />
                    <Border Height="5"
                            VerticalAlignment="Bottom"
                            Background="#2F779F"
                            CornerRadius="2,2,7,7" />
                    <Border Height="3"
                            Margin="1,0"
                            VerticalAlignment="Bottom"
                            Background="#69ADD2"
                            CornerRadius="6" />
                </Grid>

                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="ProfileNodeName"
                               Text="{Binding Name}"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock x:Name="ProfileNodeDetail"
                               Grid.Row="1"
                               Text="{Binding DetailText}"
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="11.5"
                               FontStyle="Italic"
                               TextTrimming="CharacterEllipsis"
                               Visibility="Collapsed" />
                </Grid>
            </Grid>
            <HierarchicalDataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsFolder}" Value="False">
                    <Setter TargetName="FolderIcon" Property="Visibility" Value="Collapsed" />
                    <Setter TargetName="BrokerIcon" Property="Visibility" Value="Visible" />
                    <Setter TargetName="ProfileNodeName" Property="FontWeight" Value="Normal" />
                    <Setter TargetName="ProfileNodeDetail" Property="Visibility" Value="Visible" />
                </DataTrigger>
            </HierarchicalDataTemplate.Triggers>
        </HierarchicalDataTemplate>
    </Window.Resources>

    <Grid>
        <DockPanel LastChildFill="True">
            <Border x:Name="MainHeader"
                    DockPanel.Dock="Top"
                    Height="46"
                    Background="{StaticResource ChromeBrush}"
                    Padding="10,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="132" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="*" MinWidth="24" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Image Source="Assets/mqttBoys.ico"
                               Width="24"
                               Height="24"
                               Margin="0,0,7,0" />
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="mqttBoys"
                                       Foreground="White"
                                       FontSize="16"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding AppVersionText}"
                                       Foreground="#A9C0BC"
                                       FontSize="9.5" />
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Column="1"
                             Content="Connections"
                             Command="{Binding OpenConnectionManagerCommand}"
                             Style="{StaticResource ToolbarButtonStyle}"
                             Margin="0,0,8,0" />

                    <Button Grid.Column="2"
                             x:Name="ToolsButton"
                             Content="Tools"
                             Click="ToolsButton_Click"
                             Style="{StaticResource ToolbarButtonStyle}"
                             Margin="0,0,6,0">
                        <Button.ContextMenu>
                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                <MenuItem Header="주기 체크"
                                          Command="{Binding OpenPeriodCheckCommand}" />
                                <Separator />
                                <MenuItem Header="JSON Formatter"
                                          Command="{Binding OpenJsonFormatterCommand}" />
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>

                    <TextBox x:Name="HeaderSearchInput"
                             Grid.Column="3"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Topic search"
                             Margin="0,0,12,0" />

                    <TextBlock x:Name="ConnectedBrokerCaption"
                               Grid.Column="5"
                               Text="{Binding SelectedProfileCaption}"
                               Foreground="#D9E8E5"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="320"
                               Margin="12,0,10,0" />

                    <Button x:Name="ConnectionToggleButton"
                            Grid.Column="6"
                            Content="{Binding ConnectionButtonText}"
                            Command="{Binding ToggleConnectionCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            MinWidth="92" />
                </Grid>
            </Border>

            <Grid x:Name="MainContentGrid"
                  Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="30*" MinWidth="300" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="70*" MinWidth="640" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource PanelBorderStyle}"
                        Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,10">
                            <Button DockPanel.Dock="Right"
                                    Content="Clear"
                                    Command="{Binding ClearTopicsCommand}"
                                    Style="{StaticResource QuietButtonStyle}" />
                            <TextBlock Text="Topics"
                                       Style="{StaticResource SectionTitleStyle}" />
                        </DockPanel>

                        <TreeView x:Name="TopicTree"
                                  Grid.Row="1"
                                  ItemsSource="{Binding RootTopics}"
                                  SelectedItemChanged="TopicTree_SelectedItemChanged"
                                  BorderThickness="0"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  ScrollViewer.CanContentScroll="True"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto" />
                    </Grid>
                </Border>

                <GridSplitter Grid.Column="1"
                              HorizontalAlignment="Stretch"
                              Style="{StaticResource VerticalSplitterStyle}"
                              ResizeDirection="Columns"
                              ResizeBehavior="PreviousAndNext"
                              ShowsPreview="True"
                              Cursor="SizeWE"
                              ToolTip="좌우 영역 크기 조절" />

                <Border Grid.Column="2"
                        Style="{StaticResource PanelBorderStyle}"
                        Padding="12">
                    <Grid x:Name="MainDetailGrid">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" MinHeight="180" />
                            <RowDefinition Height="7" />
                            <RowDefinition Height="170" />
                            <RowDefinition Height="7" />
                            <RowDefinition Height="*" MinHeight="210" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MinWidth="145" />
                                <ColumnDefinition Width="7" />
                                <ColumnDefinition Width="*" MinWidth="145" />
                            </Grid.ColumnDefinitions>

                            <Grid x:Name="ValuePanel"
                                  Grid.Column="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <DockPanel Margin="0,0,0,9">
                                    <StackPanel DockPanel.Dock="Right"
                                                Orientation="Horizontal">
                                        <Button x:Name="ValueChartButton"
                                                Content="Chart"
                                                Command="{Binding OpenValueChartCommand}"
                                                Style="{StaticResource QuietButtonStyle}"
                                                Margin="0,0,4,0"
                                                ToolTip="Plot numeric or boolean history" />
                                        <Button x:Name="ValuePauseButton"
                                                Content="{Binding HistoryPauseButtonText}"
                                                Command="{Binding ToggleHistoryPauseCommand}"
                                                Style="{StaticResource QuietButtonStyle}"
                                                Margin="0,0,4,0" />
                                        <Button Content="Copy"
                                                Command="{Binding CopyValueCommand}"
                                                Style="{StaticResource QuietButtonStyle}" />
                                    </StackPanel>
                                    <TextBlock Text="Value"
                                               Style="{StaticResource SectionTitleStyle}" />
                                </DockPanel>
                                <controls:JsonPayloadViewer Grid.Row="1"
                                                            Text="{Binding ValuePayloadText, Mode=OneWay}"
                                                            FontFamily="Consolas"
                                                            FontSize="12"
                                                            VerticalScrollBarVisibility="Auto"
                                                            HorizontalScrollBarVisibility="Auto"
                                                            BorderBrush="{StaticResource BorderBrushSoft}"
                                                            Background="{StaticResource CodeBackgroundBrush}"
                                                            ToolTip="Shift + 마우스 휠로 좌우 이동" />
                            </Grid>

                            <GridSplitter Grid.Column="1"
                                          HorizontalAlignment="Stretch"
                                          Style="{StaticResource VerticalSplitterStyle}"
                                          ResizeDirection="Columns"
                                          ResizeBehavior="PreviousAndNext"
                                          ShowsPreview="True"
                                          Cursor="SizeWE" />

                            <Grid Grid.Column="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <DockPanel Margin="0,0,0,9">
                                    <Button DockPanel.Dock="Right"
                                            Content="Copy"
                                            Command="{Binding CopySelectedCommand}"
                                            Style="{StaticResource QuietButtonStyle}" />
                                    <TextBlock Text="Selected"
                                               Style="{StaticResource SectionTitleStyle}" />
                                </DockPanel>
                                <controls:JsonPayloadViewer Grid.Row="1"
                                                            Text="{Binding SelectedPayloadText, Mode=OneWay}"
                                                            FontFamily="Consolas"
                                                            FontSize="12"
                                                            VerticalScrollBarVisibility="Auto"
                                                            HorizontalScrollBarVisibility="Auto"
                                                            BorderBrush="{StaticResource BorderBrushSoft}"
                                                            Background="{StaticResource CodeBackgroundBrush}"
                                                            ToolTip="Shift + 마우스 휠로 좌우 이동" />
                            </Grid>
                        </Grid>

                        <GridSplitter Grid.Row="1"
                                      HorizontalAlignment="Stretch"
                                      Style="{StaticResource HorizontalSplitterStyle}"
                                      ResizeDirection="Rows"
                                      ResizeBehavior="PreviousAndNext"
                                      ShowsPreview="True"
                                      Cursor="SizeNS" />

                        <Grid Grid.Row="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <DockPanel Margin="0,0,0,9">
                                <TextBlock Text="History"
                                           Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="{Binding SelectedTopicAveragePeriodText}"
                                           Foreground="{StaticResource MutedBrush}"
                                           VerticalAlignment="Center"
                                           Margin="12,0,0,0" />
                            </DockPanel>
                            <DataGrid Grid.Row="1"
                                      ItemsSource="{Binding SelectedTopicHistory}"
                                      SelectedItem="{Binding SelectedHistoryItem, Mode=TwoWay}"
                                      AutoGenerateColumns="False"
                                      HeadersVisibility="Column"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      EnableRowVirtualization="True"
                                      EnableColumnVirtualization="True"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling"
                                      BorderBrush="{StaticResource BorderBrushSoft}"
                                      RowHeight="28">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Time" Binding="{Binding ReceivedAtWithDeltaText}" Width="230" />
                                    <DataGridTextColumn Header="Payload" Binding="{Binding PayloadPreview}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>

                        <GridSplitter Grid.Row="3"
                                      HorizontalAlignment="Stretch"
                                      Style="{StaticResource HorizontalSplitterStyle}"
                                      ResizeDirection="Rows"
                                      ResizeBehavior="PreviousAndNext"
                                      ShowsPreview="True"
                                      Cursor="SizeNS" />

                        <Grid Grid.Row="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Publish"
                                       Style="{StaticResource SectionTitleStyle}"
                                       Margin="0,0,0,9" />
                            <Grid Grid.Row="1" Margin="0,0,0,8">
                                <TextBox x:Name="PublishTopicInput"
                                         Text="{Binding PublishTopic, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="9,5,32,5"
                                         TextChanged="PublishTopicInput_TextChanged"
                                         GotKeyboardFocus="PublishTopicInput_GotKeyboardFocus"
                                         PreviewKeyDown="PublishTopicInput_PreviewKeyDown" />
                                <Button Width="28"
                                        HorizontalAlignment="Right"
                                        Content="▼"
                                        Padding="0"
                                        Style="{StaticResource QuietButtonStyle}"
                                        Click="PublishTopicDropButton_Click"
                                        ToolTip="Show known topics" />
                                <Popup x:Name="PublishTopicPopup"
                                       PlacementTarget="{Binding ElementName=PublishTopicInput}"
                                       DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                       Placement="Bottom"
                                       StaysOpen="False"
                                       AllowsTransparency="True"
                                       PopupAnimation="Fade">
                                    <Border Width="{Binding ActualWidth, ElementName=PublishTopicInput}"
                                            MaxHeight="220"
                                            Background="White"
                                            BorderBrush="{StaticResource BorderBrushStrong}"
                                            BorderThickness="1">
                                        <ListBox x:Name="PublishTopicSuggestionList"
                                                 ItemsSource="{Binding PublishTopicSuggestions}"
                                                 PreviewMouseLeftButtonUp="PublishTopicSuggestionList_PreviewMouseLeftButtonUp"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}"
                                                               Margin="4,2"
                                                               TextTrimming="CharacterEllipsis" />
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Border>
                                </Popup>
                            </Grid>
                            <TextBox x:Name="PublishPayloadInput"
                                     Grid.Row="2"
                                     Text="{Binding PublishPayload, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     AcceptsTab="True"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     VerticalContentAlignment="Top"
                                     Background="{StaticResource CodeBackgroundBrush}" />
                            <Grid Grid.Row="3" Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="72" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="QoS"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0" />
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding QosOptions}"
                                          SelectedItem="{Binding PublishQos}" />
                                <CheckBox Grid.Column="2"
                                          Content="retain"
                                          IsChecked="{Binding PublishRetain}"
                                          VerticalAlignment="Center"
                                          Margin="14,0" />
                                <Button Grid.Column="4"
                                        Content="Format JSON"
                                        Command="{Binding FormatPublishJsonCommand}"
                                        Margin="0,0,8,0" />
                                <Button Grid.Column="5"
                                        Content="Publish"
                                        Command="{Binding PublishCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        MinWidth="100" />
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </DockPanel>

        <Border x:Name="ValueChartFlyout"
                Width="720"
                Height="380"
                Margin="0,58,18,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Background="White"
                CornerRadius="6"
                Effect="{StaticResource ModalShadow}"
                Visibility="{Binding ValueChartVisibility}"
                Panel.ZIndex="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="48" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="38" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#FBFCFC"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="0,0,0,1"
                        CornerRadius="6,6,0,0"
                        Padding="14,0">
                    <DockPanel>
                        <Button DockPanel.Dock="Right"
                                Content="Close"
                                Command="{Binding CloseValueChartCommand}"
                                Style="{StaticResource QuietButtonStyle}"
                                VerticalAlignment="Center" />
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Value chart"
                                       Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock Text="{Binding ValueChartTopicText}"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="11.5"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="590" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Grid Grid.Row="1" Margin="14,12,14,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Field"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Margin="0,0,9,0" />
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding ValueChartMetrics}"
                              SelectedItem="{Binding SelectedValueChartMetric, Mode=TwoWay}"
                              DisplayMemberPath="DisplayPath"
                              MinWidth="320"
                              MaxDropDownHeight="300" />
                    <TextBlock Grid.Column="2"
                               Text="{Binding ValueChartStatusText}"
                               Foreground="{StaticResource MutedBrush}"
                               VerticalAlignment="Center"
                               Margin="14,0,0,0" />
                </Grid>

                <controls:ScalarHistoryChart Grid.Row="2"
                                             Values="{Binding ValueChartValues}"
                                             IsBoolean="{Binding ValueChartIsBoolean}"
                                             Margin="10,0,10,0" />

                <Grid Grid.Row="3"
                      Margin="16,0"
                      VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding ValueChartStartText}"
                               Foreground="{StaticResource MutedBrush}" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding ValueChartSummaryText}"
                               HorizontalAlignment="Center"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="2"
                               Text="{Binding ValueChartEndText}"
                               Foreground="{StaticResource MutedBrush}" />
                </Grid>
            </Grid>
        </Border>

        <Grid Visibility="{Binding ConnectionManagerVisibility}"
              Background="#B3182422">
            <Grid Width="1040"
                  Height="680"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  UseLayoutRounding="True"
                  SnapsToDevicePixels="True">
                <Border Background="White"
                        CornerRadius="8"
                        Effect="{StaticResource ModalShadow}"
                        IsHitTestVisible="False" />
                <Border Background="White"
                        BorderBrush="{StaticResource BorderBrushStrong}"
                        BorderThickness="1"
                        CornerRadius="8"
                        SnapsToDevicePixels="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="58" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="64" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300" />
                        <ColumnDefinition Width="1" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Row="0"
                            Grid.ColumnSpan="3"
                            Background="#FBFCFC"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="0,0,0,1"
                            Padding="20,0">
                        <DockPanel>
                            <Button DockPanel.Dock="Right"
                                    Content="Close"
                                    Command="{Binding CloseConnectionManagerCommand}"
                                    Style="{StaticResource QuietButtonStyle}"
                                    VerticalAlignment="Center" />
                            <TextBlock Text="Connections"
                                       Style="{StaticResource ModalTitleStyle}" />
                        </DockPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Grid.Column="0"
                            Background="#F8FAFA"
                            Padding="16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Saved connections"
                                       Style="{StaticResource SectionTitleStyle}"
                                       Margin="2,0,0,12" />

                            <TreeView x:Name="ProfileTree"
                                      Grid.Row="1"
                                      ItemsSource="{Binding ProfileTree}"
                                      ItemContainerStyle="{StaticResource ProfileTreeItemStyle}"
                                      SelectedItemChanged="ProfileTree_SelectedItemChanged"
                                      PreviewMouseLeftButtonDown="ProfileTree_PreviewMouseLeftButtonDown"
                                      MouseMove="ProfileTree_MouseMove"
                                      DragOver="ProfileTree_DragOver"
                                      Drop="ProfileTree_Drop"
                                      AllowDrop="True"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto" />

                            <Grid Grid.Row="2" Margin="0,14,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <UniformGrid Columns="2">
                                    <Button Content="Add broker"
                                            Command="{Binding AddProfileCommand}"
                                            Margin="0,0,4,4" />
                                    <Button Content="Add folder"
                                            Command="{Binding AddFolderCommand}"
                                            Margin="4,0,0,4" />
                                </UniformGrid>
                                <UniformGrid Grid.Row="1" Columns="2">
                                    <Button Content="Delete broker"
                                            Command="{Binding DeleteProfileCommand}"
                                            Style="{StaticResource DangerButtonStyle}"
                                            Margin="0,4,4,0" />
                                    <Button Content="Delete folder"
                                            Command="{Binding DeleteFolderCommand}"
                                            Style="{StaticResource DangerButtonStyle}"
                                            Margin="4,4,0,0" />
                                </UniformGrid>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Grid.Column="1"
                            Background="{StaticResource BorderBrushSoft}" />

                    <ScrollViewer Grid.Row="1"
                                  Grid.Column="2"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="24,18,20,18">
                        <Grid>
                            <StackPanel Visibility="{Binding BrokerEditorVisibility}">
                                <TextBlock Text="Broker"
                                           Style="{StaticResource SectionTitleStyle}"
                                           Margin="0,0,0,10" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="2*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Folder" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBox Grid.Row="1" Grid.Column="0" Text="{Binding SelectedProfile.Name, UpdateSourceTrigger=PropertyChanged}" />
                                    <ComboBox x:Name="FolderCombo"
                                              Grid.Row="1"
                                              Grid.Column="2"
                                              ItemsSource="{Binding FolderOptions}"
                                              SelectedItem="{Binding SelectedProfileFolderPath, Mode=OneWay}"
                                              SelectionChanged="FolderCombo_SelectionChanged"
                                              IsEditable="False" />
                                </Grid>

                                <Border Height="1"
                                        Background="{StaticResource BorderBrushSoft}"
                                        Margin="0,18" />

                                <TextBlock Text="Connection"
                                           Style="{StaticResource SectionTitleStyle}"
                                           Margin="0,0,0,10" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="160" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Protocol" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Host" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBlock Grid.Row="0" Grid.Column="4" Text="Port" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBlock Grid.Row="0" Grid.Column="6" Text="WS path" Style="{StaticResource FieldLabelStyle}" />
                                    <ComboBox Grid.Row="1" Grid.Column="0" ItemsSource="{Binding TransportOptions}" SelectedItem="{Binding SelectedProfile.Transport, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding SelectedProfile.Host, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Grid.Row="1" Grid.Column="4" Text="{Binding SelectedProfile.Port, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Grid.Row="1" Grid.Column="6" Text="{Binding SelectedProfile.WebSocketPath, UpdateSourceTrigger=PropertyChanged}" />
                                    <StackPanel Grid.Row="2"
                                                Grid.Column="0"
                                                Grid.ColumnSpan="7"
                                                Orientation="Horizontal"
                                                Margin="0,12,0,0">
                                        <CheckBox Content="Encryption (TLS)"
                                                  IsChecked="{Binding SelectedProfile.UseTls}"
                                                  Margin="0,0,24,0" />
                                        <CheckBox Content="Validate certificate"
                                                  IsChecked="{Binding SelectedProfile.ValidateCertificate}" />
                                    </StackPanel>
                                </Grid>

                                <Border Height="1"
                                        Background="{StaticResource BorderBrushSoft}"
                                        Margin="0,18" />

                                <TextBlock Text="Session"
                                           Style="{StaticResource SectionTitleStyle}"
                                           Margin="0,0,0,10" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="110" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Client ID" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Subscribe" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBlock Grid.Row="0" Grid.Column="4" Text="History" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBox Grid.Row="1" Grid.Column="0" Text="{Binding SelectedProfile.ClientId, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding SelectedProfile.SubscribeTopic, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Grid.Row="1" Grid.Column="4" Text="{Binding SelectedProfile.MaxHistoryPerTopic, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>

                                <Border Height="1"
                                        Background="{StaticResource BorderBrushSoft}"
                                        Margin="0,18" />

                                <TextBlock Text="Credentials"
                                           Style="{StaticResource SectionTitleStyle}"
                                           Margin="0,0,0,10" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Username" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Password" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBox Grid.Row="1" Grid.Column="0" Text="{Binding SelectedProfile.Username, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding SelectedProfile.Password, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>

                                <Expander IsExpanded="{Binding SelectedProfile.EnableSshTunnel, Mode=TwoWay}"
                                          Margin="0,18,0,0">
                                    <Expander.Header>
                                        <CheckBox Content="Use SSH tunnel"
                                                  IsChecked="{Binding SelectedProfile.EnableSshTunnel, Mode=TwoWay}"
                                                  FontWeight="SemiBold" />
                                    </Expander.Header>
                                    <Border Background="{StaticResource SurfaceAltBrush}"
                                            BorderBrush="{StaticResource BorderBrushSoft}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="14"
                                            Margin="0,10,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="16" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="100" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="12" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="12" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="SSH host" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBlock Grid.Row="0" Grid.Column="2" Text="SSH port" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBlock Grid.Row="0" Grid.Column="4" Text="SSH user" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBlock Grid.Row="0" Grid.Column="6" Text="Local port" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBox Grid.Row="1" Grid.Column="0" Text="{Binding SelectedProfile.SshHost, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding SelectedProfile.SshPort, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBox Grid.Row="1" Grid.Column="4" Text="{Binding SelectedProfile.SshUsername, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBox Grid.Row="1" Grid.Column="6" Text="{Binding SelectedProfile.SshLocalPort, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="7" Text="Private key" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBox Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="7" Text="{Binding SelectedProfile.SshPrivateKeyPath, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Grid.Row="6"
                                                       Grid.Column="0"
                                                       Grid.ColumnSpan="7"
                                                       Text="Uses OpenSSH config, a private key, or ssh-agent. Broker Host and Port remain the target visible from the SSH host."
                                                       Foreground="{StaticResource MutedBrush}"
                                                       FontSize="12"
                                                       TextWrapping="Wrap" />
                                        </Grid>
                                    </Border>
                                </Expander>
                            </StackPanel>

                            <StackPanel Visibility="{Binding FolderEditorVisibility}">
                                <TextBlock Text="Folder"
                                           Style="{StaticResource SectionTitleStyle}"
                                           Margin="0,0,0,14" />
                                <TextBlock Text="Name" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Text="{Binding SelectedFolderName, UpdateSourceTrigger=PropertyChanged}" />

                                <Grid Margin="0,18,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Path" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedFolderFullPath}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Parent" Style="{StaticResource FieldLabelStyle}" Margin="0,12,0,5" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedFolderParentPath}" TextTrimming="CharacterEllipsis" Margin="0,12,0,5" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedFolderSummaryText}" Foreground="{StaticResource MutedBrush}" Margin="0,12,0,0" />
                                </Grid>

                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            Margin="0,20,0,0">
                                    <Button Content="Rename folder"
                                            Command="{Binding RenameFolderCommand}"
                                            Margin="0,0,8,0" />
                                    <Button Content="Delete folder"
                                            Command="{Binding DeleteFolderCommand}"
                                            Style="{StaticResource DangerButtonStyle}" />
                                </StackPanel>
                            </StackPanel>

                            <Grid Visibility="{Binding EmptyConnectionEditorVisibility}">
                                <TextBlock Text="Select a broker or folder"
                                           Style="{StaticResource SectionTitleStyle}"
                                           Foreground="{StaticResource MutedBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Grid>
                    </ScrollViewer>

                    <Border Grid.Row="2"
                            Grid.ColumnSpan="3"
                            Background="{StaticResource SurfaceAltBrush}"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="0,1,0,0"
                            Padding="18,0">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <Button Content="Save changes"
                                    Command="{Binding SaveProfilesCommand}"
                                    Margin="0,0,10,0" />
                            <Button Content="Connect"
                                    Command="{Binding ConnectSelectedProfileCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    MinWidth="116" />
                        </StackPanel>
                    </Border>
                </Grid>
                </Border>
            </Grid>
        </Grid>
        <Grid x:Name="PeriodCheckPanel"
              Visibility="{Binding PeriodCheckVisibility}"
              IsVisibleChanged="PeriodCheckPanel_IsVisibleChanged"
              Background="#B3182422">
            <Grid Width="920"
                  Height="650"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  UseLayoutRounding="True"
                  SnapsToDevicePixels="True">
                <Border Background="White"
                        CornerRadius="8"
                        Effect="{StaticResource ModalShadow}"
                        IsHitTestVisible="False" />
                <Border Background="White"
                        BorderBrush="{StaticResource BorderBrushStrong}"
                        BorderThickness="1"
                        CornerRadius="8"
                        SnapsToDevicePixels="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="58" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#FBFCFC"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="0,0,0,1"
                            Padding="20,0">
                        <DockPanel>
                            <Button DockPanel.Dock="Right"
                                    Content="닫기"
                                    Command="{Binding ClosePeriodCheckCommand}"
                                    Style="{StaticResource QuietButtonStyle}"
                                    VerticalAlignment="Center" />
                            <TextBlock Text="주기 체크"
                                       Style="{StaticResource ModalTitleStyle}" />
                            <Border Background="{StaticResource AccentSoftBrush}"
                                    CornerRadius="5"
                                    Padding="9,4"
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding PeriodCheckRunningText}"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontWeight="SemiBold" />
                            </Border>
                        </DockPanel>
                    </Border>

                    <Grid Grid.Row="1" Margin="22,18,22,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="180" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Text="토픽"
                                       Style="{StaticResource FieldLabelStyle}" />
                            <TextBlock Grid.Row="0"
                                       Grid.Column="2"
                                       Text="측정 시간"
                                       Style="{StaticResource FieldLabelStyle}" />
                            <Grid x:Name="PeriodTopicInputHost"
                                  Grid.Row="1"
                                  Grid.Column="0">
                                <TextBox x:Name="PeriodTopicInput"
                                         Text="{Binding PeriodCheckTopicText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="9,5,36,5"
                                         IsEnabled="{Binding IsPeriodCheckIdle}"
                                         TextChanged="PeriodTopicInput_TextChanged"
                                         GotKeyboardFocus="PeriodTopicInput_GotKeyboardFocus"
                                         PreviewKeyDown="PeriodTopicInput_PreviewKeyDown" />
                                <Button HorizontalAlignment="Right"
                                        VerticalAlignment="Stretch"
                                        Width="34"
                                        MinHeight="0"
                                        Padding="0"
                                        Content="▼"
                                        FontSize="9"
                                        Foreground="{StaticResource MutedBrush}"
                                        Style="{StaticResource QuietButtonStyle}"
                                        ToolTip="토픽 목록 열기"
                                        Click="PeriodTopicDropButton_Click" />
                                <Popup x:Name="PeriodTopicPopup"
                                       PlacementTarget="{Binding ElementName=PeriodTopicInputHost}"
                                       DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                       Placement="Bottom"
                                       VerticalOffset="2"
                                       AllowsTransparency="True"
                                       StaysOpen="False"
                                       Focusable="False">
                                    <Border Width="{Binding ActualWidth, ElementName=PeriodTopicInputHost}"
                                            MaxHeight="264"
                                            Background="White"
                                            BorderBrush="{StaticResource BorderBrushStrong}"
                                            BorderThickness="1"
                                            SnapsToDevicePixels="True">
                                        <ListBox x:Name="PeriodTopicSuggestionList"
                                                 ItemsSource="{Binding PeriodCheckTopicSuggestions}"
                                                 Background="White"
                                                 BorderThickness="0"
                                                 Padding="0,3"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                 PreviewMouseLeftButtonUp="PeriodTopicSuggestionList_PreviewMouseLeftButtonUp">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}"
                                                               TextTrimming="CharacterEllipsis" />
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="Padding" Value="9,6" />
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                    <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
                                                    <Setter Property="Background" Value="White" />
                                                    <Setter Property="Cursor" Value="Hand" />
                                                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter Property="Background" Value="#CFE6E1" />
                                                            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                        </ListBox>
                                    </Border>
                                </Popup>
                            </Grid>
                            <ComboBox Grid.Row="1"
                                      Grid.Column="2"
                                      ItemsSource="{Binding PeriodCheckDurationOptions}"
                                      Text="{Binding PeriodCheckDurationText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      IsEditable="True"
                                      IsTextSearchEnabled="False"
                                      IsEnabled="{Binding IsPeriodCheckIdle}"
                                      ToolTip="10초, 30초, 1분 또는 원하는 초를 직접 입력" />
                            <Button Grid.Row="1"
                                    Grid.Column="4"
                                    Content="측정 시작"
                                    Command="{Binding StartPeriodCheckCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    MinHeight="36"
                                    Visibility="{Binding IsPeriodCheckIdle, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <Button Grid.Row="1"
                                    Grid.Column="4"
                                    Content="측정 중단"
                                    Command="{Binding StopPeriodCheckCommand}"
                                    Style="{StaticResource DangerButtonStyle}"
                                    MinHeight="36"
                                    Visibility="{Binding IsPeriodCheckRunning, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </Grid>

                        <Border Grid.Row="1"
                                Background="{StaticResource AccentSoftBrush}"
                                CornerRadius="6"
                                Padding="12,10"
                                Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="상태"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentBrush}"
                                           Margin="0,0,12,0" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding PeriodCheckStatus}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="2"
                                           Text="{Binding PeriodCheckDurationSummaryText}"
                                           Foreground="{StaticResource MutedBrush}"
                                           Margin="16,0,0,0" />
                            </Grid>
                        </Border>

                        <Grid Grid.Row="2" Margin="0,0,0,16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="현재 결과"
                                       Style="{StaticResource SectionTitleStyle}"
                                       Margin="0,0,0,8" />
                            <TextBox Grid.Row="1"
                                     Text="{Binding PeriodCheckResultText, Mode=OneWay}"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     Background="{StaticResource CodeBackgroundBrush}"
                                     BorderBrush="{StaticResource BorderBrushSoft}"
                                     VerticalContentAlignment="Top" />
                        </Grid>

                        <Grid Grid.Row="3">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock DockPanel.Dock="Right"
                                           Text="앱 종료 시 초기화"
                                           Foreground="{StaticResource MutedBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="측정 기록"
                                           Style="{StaticResource SectionTitleStyle}" />
                            </DockPanel>
                            <DataGrid Grid.Row="1"
                                      ItemsSource="{Binding PeriodCheckHistory}"
                                      SelectedItem="{Binding SelectedPeriodCheckHistoryItem, Mode=TwoWay}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      EnableRowVirtualization="True"
                                      EnableColumnVirtualization="True"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="완료 시각" Binding="{Binding CompletedAtText}" Width="165" />
                                    <DataGridTextColumn Header="토픽" Binding="{Binding Topic}" Width="2*" />
                                    <DataGridTextColumn Header="결과" Binding="{Binding Summary}" Width="3*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Grid>
                </Grid>
                </Border>
            </Grid>
        </Grid>

        <Grid x:Name="JsonFormatterPanel"
              Visibility="{Binding JsonFormatterVisibility}"
              Background="#B3182422"
              Panel.ZIndex="40">
            <Grid x:Name="JsonFormatterDialog"
                  Width="1040"
                  Height="650"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  UseLayoutRounding="True"
                  SnapsToDevicePixels="True">
                <Border Background="White"
                        CornerRadius="8"
                        Effect="{StaticResource ModalShadow}"
                        IsHitTestVisible="False" />
                <Border Background="White"
                        BorderBrush="{StaticResource BorderBrushStrong}"
                        BorderThickness="1"
                        CornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="56" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="38" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="#FBFCFC"
                                BorderBrush="{StaticResource BorderBrushSoft}"
                                BorderThickness="0,0,0,1"
                                CornerRadius="8,8,0,0"
                                Padding="18,0">
                            <DockPanel>
                                <Button DockPanel.Dock="Right"
                                        Content="Close"
                                        Command="{Binding CloseJsonFormatterCommand}"
                                        Style="{StaticResource QuietButtonStyle}"
                                        VerticalAlignment="Center" />
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="JSON Formatter"
                                               Style="{StaticResource ModalTitleStyle}" />
                                    <TextBlock Text="Format, validate, and copy JSON without leaving mqttBoys"
                                               Foreground="{StaticResource MutedBrush}"
                                               FontSize="11.5" />
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <StackPanel Grid.Row="1"
                                    Orientation="Horizontal"
                                    Margin="18,12,18,10">
                            <Button Content="Format"
                                    Command="{Binding FormatJsonFormatterCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    MinWidth="88"
                                    Margin="0,0,8,0" />
                            <Button Content="Compact"
                                    Command="{Binding CompactJsonFormatterCommand}"
                                    Margin="0,0,8,0" />
                            <Button Content="Validate"
                                    Command="{Binding ValidateJsonFormatterCommand}"
                                    Margin="0,0,8,0" />
                            <Button Content="Copy result"
                                    Command="{Binding CopyJsonFormatterCommand}"
                                    Margin="0,0,8,0" />
                            <Button Content="Clear"
                                    Command="{Binding ClearJsonFormatterCommand}"
                                    Style="{StaticResource QuietButtonStyle}" />
                        </StackPanel>

                        <Grid Grid.Row="2" Margin="18,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Input"
                                       Style="{StaticResource SectionTitleStyle}"
                                       Margin="0,0,0,8" />
                            <TextBlock Grid.Column="2"
                                       Text="Formatted result"
                                       Style="{StaticResource SectionTitleStyle}"
                                       Margin="0,0,0,8" />

                            <TextBox Grid.Row="1"
                                     Text="{Binding JsonFormatterInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     AcceptsTab="True"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     TextWrapping="NoWrap"
                                     VerticalContentAlignment="Top"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     Background="{StaticResource CodeBackgroundBrush}" />

                            <controls:JsonPayloadViewer Grid.Row="1"
                                                        Grid.Column="2"
                                                        Text="{Binding JsonFormatterOutput, Mode=OneWay}"
                                                        FontFamily="Consolas"
                                                        FontSize="12"
                                                        VerticalScrollBarVisibility="Auto"
                                                        HorizontalScrollBarVisibility="Auto"
                                                        BorderBrush="{StaticResource BorderBrushSoft}"
                                                        Background="{StaticResource CodeBackgroundBrush}" />
                        </Grid>

                        <Border Grid.Row="3"
                                Background="{StaticResource SurfaceAltBrush}"
                                BorderBrush="{StaticResource BorderBrushSoft}"
                                BorderThickness="0,1,0,0"
                                CornerRadius="0,0,8,8"
                                Padding="18,0">
                            <TextBlock Text="{Binding JsonFormatterStatus}"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource MutedBrush}"
                                       TextTrimming="CharacterEllipsis" />
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
